    "star.tanlang": {
      "type": "star_vector",
      "source_ids": ["lyric.sihua.002", "star.tanlang.001"],
      "notes": "北斗星，木行，化氣為善。主桃花慾望與多才多藝。戊幹化祿主星。"
    },
    "star.qisha": {
      "type": "star_vector",
      "source_ids": ["lyric.gusui.001", "star.qisha.001"],
      "notes": "南斗星，火金行，化氣為權。主武勇決斷，帶孤克之性。"
    },
    "star.pojun": {
      "type": "star_vector",
      "source_ids": ["lyric.sihua.001", "quanshu.v2.caibo.003", "star.pojun.001"],
      "notes": "北斗星，水行，化氣為耗。主破壞重建，消耗極大但變革力最強。"
    },
    "star.tianxiang": {
      "type": "star_vector",
      "source_ids": ["star.tianxiang.001"],
      "notes": "南斗星，水行，化氣為印。主輔佐禮儀文書，為宰相之星。"
    },
    "star.wenqu": {
      "type": "star_vector",
      "source_ids": ["star.wenqu.001"],
      "notes": "北斗星，水行。與文昌對，主口才藝術。化忌主是非。"
    },
    "star.tiankui": {
      "type": "star_vector",
      "source_ids": ["star.tiankui.001"],
      "notes": "南斗星，日間貴人。主科甲晉升逢凶化吉。與天鉞為一對。"
    },
    "star.tianyue": {
      "type": "star_vector",
      "source_ids": ["star.tianyue.001"],
      "notes": "南斗星，夜間貴人。主科甲晉升逢凶化吉。與天魁為一對。"
    }
  }
